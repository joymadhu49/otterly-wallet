{
  "name": "otterly-wallet",
  "version": "0.1.6",
  "description": "Otterly Wallet — friendly self-custodial Chrome extension for the Arc Network. USDC-native gas, instant finality.",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "webpack --config webpack.config.js --mode development --watch",
    "build": "webpack --config webpack.config.js --mode production",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "zip": "npm run clean && npm run build && cd dist && zip -r ../otterly-wallet.zip . && cd .."
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.7",
    "@metamask/browser-passworder": "^4.3.0",
    "@noble/hashes": "^1.4.0",
    "@reduxjs/toolkit": "^2.2.5",
    "@scure/bip39": "^1.3.0",
    "antd": "^5.18.3",
    "bignumber.js": "^9.1.2",
    "ethers": "^5.7.2",
    "eventemitter3": "^5.0.1",
    "framer-motion": "^11.2.10",
    "qrcode.react": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.23.1",
    "redux-persist": "^6.0.0",
    "webextension-polyfill": "^0.12.0",
    "buffer": "^6.0.3",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/webextension-polyfill": "^0.10.7",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.0",
    "less": "^4.2.0",
    "less-loader": "^12.2.0",
    "mini-css-extract-plugin": "^2.9.0",
    "rimraf": "^5.0.7",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "webpack": "^5.92.0",
    "webpack-cli": "^5.1.4"
  }
}
